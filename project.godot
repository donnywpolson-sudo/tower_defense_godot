; Engine configuration file.
; Prefer editing through the Godot editor when possible.
;
; Format:
;   [section]
;   param=value

config_version=5

[application]

config/name="Tower Defense Godot"
config/description="Godot 4 tower defense with project-local canonical data and validation."
config/version="0.3.0-godot-owned"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "Mobile")

[autoload]

GameConfig="*res://scripts/autoload/game_config.gd"
GameData="*res://scripts/autoload/game_data.gd"
GameAssets="*res://scripts/autoload/game_assets.gd"
GameAudio="*res://scripts/autoload/game_audio.gd"
GameProgress="*res://scripts/autoload/game_progress.gd"
ParityHarness="*res://scripts/autoload/parity_harness.gd"

[display]

window/size/viewport_width=1180
window/size/viewport_height=600
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

