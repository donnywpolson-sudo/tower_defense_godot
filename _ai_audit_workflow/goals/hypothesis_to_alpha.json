{
  "schema_version": 1,
  "goal_id": "hypothesis_to_alpha",
  "hypothesis": {
    "id": "balance_first_alpha_v1",
    "statement": "A deterministic, evidence-gated balance pass across the tower families can produce a runnable, regression-safe Godot alpha candidate.",
    "alpha_definition": "A project export artifact exists, loads through the configured main scene, and passes the required data, gameplay, workflow, and export gates."
  },
  "objective": "Turn the current gameplay hypothesis into a validated runnable alpha candidate, or stop with the smallest concrete blocker.",
  "mutation_policy": {
    "mode": "delegated_child_goals",
    "automatic": true,
    "allowed_child_goals": ["frost_balance", "tower_balance_sweep"],
    "allowed_files": [],
    "allowed_json_paths": [],
    "allowed_values": [],
    "forbidden_surfaces": [
      "root-level gameplay or data mutation",
      "unregistered child goals",
      "staging, commits, and pushes"
    ]
  },
  "protected_files": [
    "scripts/game/vertical_slice_game.gd",
    "scripts/tools/run_ai_simulation_batch.gd",
    "scripts/tools/run_split_frost_counterfactual_validation.gd",
    "scripts/tools/run_split_frost_shatter_ablation_evidence_report.gd",
    "_ai_audit_workflow/PURSUE_GOAL.ps1",
    "_ai_audit_workflow/_internal/pursue_goal.ps1",
    "_ai_audit_workflow/goals/frost_balance.json",
    "_ai_audit_workflow/goals/tower_balance_sweep.json",
    "logs/godot/split_frost_broader_paired_replay_2026_07_14.json",
    "logs/godot/split_frost_candidate_evidence_2026_07_14.json",
    "logs/godot/split_frost_cost_matched_paired_replay_2026_07_14.json",
    "logs/godot/split_frost_cost_matched_evidence_2026_07_14.json"
  ],
  "stop_policy": {
    "max_stage_attempts": 1,
    "terminal_statuses": ["complete", "blocked", "needs_approval"],
    "fail_closed": true
  },
  "stages": [
    {
      "id": "frost_child_goal",
      "type": "child_goal",
      "goal": "frost_balance",
      "log": "logs/godot/pursue_goal/hypothesis_to_alpha/frost_child.log",
      "timeout_seconds": 1800
    },
    {
      "id": "tower_balance_child_goal",
      "type": "child_goal",
      "goal": "tower_balance_sweep",
      "log": "logs/godot/pursue_goal/hypothesis_to_alpha/tower_balance_child.log",
      "timeout_seconds": 2400
    },
    {
      "id": "frost_state_gate",
      "type": "assert_json",
      "file": "data/game_data.json",
      "assertions": [
        { "path": "towers/branch_definitions/frost/shatter/runtime_effects/death_burst_damage_ratio", "equals": 0.18 }
      ]
    },
    {
      "id": "data_validation",
      "type": "run_godot",
      "script": "res://scripts/tools/run_data_validation.gd",
      "arguments": [],
      "log": "logs/godot/pursue_goal/hypothesis_to_alpha/data_validation.log",
      "timeout_seconds": 300,
      "expected_token": "DATA_VALIDATION_OK"
    },
    {
      "id": "vertical_slice_validation",
      "type": "run_godot",
      "script": "res://scripts/tools/run_vertical_slice_smoke.gd",
      "arguments": [],
      "log": "logs/godot/pursue_goal/hypothesis_to_alpha/vertical_slice_validation.log",
      "timeout_seconds": 300,
      "expected_token": "VERTICAL_SLICE_SMOKE_OK"
    },
    {
      "id": "export_platform_validation",
      "type": "run_godot",
      "script": "res://scripts/tools/run_export_platform_validation.gd",
      "arguments": [],
      "log": "logs/godot/pursue_goal/hypothesis_to_alpha/export_platform_validation.log",
      "timeout_seconds": 300,
      "expected_token": "EXPORT_PLATFORM_VALIDATION_OK"
    },
    {
      "id": "workflow_contract_validation",
      "type": "run_godot",
      "script": "res://scripts/tools/run_ai_workflow_contract_validation.gd",
      "arguments": [],
      "log": "logs/godot/pursue_goal/hypothesis_to_alpha/workflow_contract_validation.log",
      "timeout_seconds": 900,
      "expected_token": "AI_WORKFLOW_CONTRACT_VALIDATION_OK"
    },
    { "id": "protected_files_unchanged", "type": "protected_hashes" },
    { "id": "diff_check", "type": "git_diff_check" },
    { "id": "process_cleanup", "type": "process_clean" },
    {
      "id": "alpha_export_preset",
      "type": "assert_file",
      "file": "export_presets.cfg"
    },
    {
      "id": "alpha_export",
      "type": "run_godot_export",
      "preset": "Windows Desktop",
      "output": ".godot/alpha/TowerDefense.exe",
      "log": "logs/godot/pursue_goal/hypothesis_to_alpha/alpha_export.log",
      "timeout_seconds": 900
    },
    {
      "id": "alpha_artifact",
      "type": "assert_file",
      "file": ".godot/alpha/TowerDefense.exe"
    }
  ]
}
