{
  "schema_version": 1,
  "goal_id": "balance_depth_60",
  "objective": "Run a bounded one-hour balance-and-depth audit across enemy pressure, all supported towers, upgrade branches, economy, and role overlap; produce deterministic evidence and stop before any unapproved mutation.",
  "mutation_policy": {
    "mode": "report_only_fail_closed",
    "automatic": false,
    "allowed_files": [],
    "allowed_json_paths": [],
    "allowed_values": [],
    "forbidden_surfaces": [
      "data/game_data.json",
      "scripts/game/vertical_slice_game.gd",
      "scripts/tools/run_ai_simulation_batch.gd",
      "tower values without a candidate-specific contract",
      "wave schedule or enemy-strength values without a candidate-specific contract",
      "staging, commits, and pushes"
    ]
  },
  "protected_files": [
    "data/game_data.json",
    "scripts/game/vertical_slice_game.gd",
    "scripts/tools/run_ai_simulation_batch.gd",
    "scripts/tools/run_wave_pressure_counterfactual_validation.gd",
    "_ai_audit_workflow/_internal/config.json"
  ],
  "stop_policy": {
    "wall_clock_budget_minutes": 60,
    "max_stage_attempts": 1,
    "terminal_statuses": ["complete", "blocked", "needs_approval"],
    "fail_closed": true
  },
  "stages": [
    {
      "id": "all_family_medium_audit",
      "type": "run_godot",
      "script": "res://scripts/tools/run_ai_simulation_batch.gd",
      "arguments": [
        "--profile=medium",
        "--runs=420",
        "--max-waves=6",
        "--seed-count=5",
        "--strategy-group=standard_research",
        "--map-set=all",
        "--coverage=full",
        "--scenario-probes=auto",
        "--record=flagged",
        "--report-label=balance_depth_60",
        "--output-dir=res://.godot/ai_simulation/balance_depth_60",
        "--report-only"
      ],
      "log": "logs/godot/pursue_goal/balance_depth_60/all_family_medium_audit.log",
      "timeout_seconds": 1800,
      "expected_token": "AI_SIMULATION_BATCH_OK"
    },
    {
      "id": "packet_coverage_gate",
      "type": "assert_latest_json",
      "directory": ".godot/ai_simulation/balance_depth_60",
      "prefix": "ai_simulation_data_",
      "suffix": ".json",
      "assertions": [
        { "path": "schema_version", "equals": 7 },
        { "path": "config/profile", "equals": "medium" },
        { "path": "config/runs", "equals": 420 },
        { "path": "config/max_waves", "equals": 6 },
        { "path": "config/seed_count", "equals": 5 },
        { "path": "config/map_set", "equals": "all" },
        { "path": "config/report_only", "equals": true },
        { "path": "summary/failed_runs", "equals": 0 },
        { "path": "tower_metrics/archer/placements", "greater_than": 0 },
        { "path": "tower_metrics/machine_gun/placements", "greater_than": 0 },
        { "path": "tower_metrics/cannon/placements", "greater_than": 0 },
        { "path": "tower_metrics/frost/placements", "greater_than": 0 },
        { "path": "tower_metrics/poison/placements", "greater_than": 0 },
        { "path": "tower_metrics/sniper/placements", "greater_than": 0 },
        { "path": "tower_metrics/tesla/placements", "greater_than": 0 },
        { "path": "gameplay_depth_metrics/branch_catalog_count", "equals": 21 },
        { "path": "gameplay_depth_metrics/tower_pick_entropy", "greater_than": 0.5 },
        { "path": "gameplay_depth_metrics/branch_pick_entropy", "greater_than": 0.5 }
      ]
    },
    {
      "id": "wave_pressure_matrix",
      "type": "run_godot",
      "script": "res://scripts/tools/run_wave_pressure_counterfactual_validation.gd",
      "arguments": [],
      "log": "logs/godot/pursue_goal/balance_depth_60/wave_pressure_matrix.log",
      "timeout_seconds": 300,
      "expected_token": "WAVE_PRESSURE_COUNTERFACTUAL_VALIDATION_OK"
    },
    {
      "id": "wave_pressure_gate",
      "type": "assert_json",
      "file": "logs/godot/wave_pressure_counterfactual_2026_07_14.json",
      "assertions": [
        { "path": "evidence_only", "equals": true },
        { "path": "no_canonical_mutation", "equals": true },
        { "path": "summary/case_count", "equals": 48 },
        { "path": "candidate_gate/structural_all_passed", "equals": true },
        { "path": "candidate_gate/determinism_all_passed", "equals": true },
        { "path": "candidate_gate/shared_total_spend", "equals": true },
        { "path": "candidate_gate/recommendation_status", "equals": "no_candidate" }
      ]
    },
    {
      "id": "workflow_contract_validation",
      "type": "run_godot",
      "script": "res://scripts/tools/run_ai_workflow_contract_validation.gd",
      "arguments": [],
      "log": "logs/godot/pursue_goal/balance_depth_60/workflow_contract_validation.log",
      "timeout_seconds": 900,
      "expected_token": "AI_WORKFLOW_CONTRACT_VALIDATION_OK"
    },
    {
      "id": "recommendation_contract_validation",
      "type": "run_godot",
      "script": "res://scripts/tools/run_ai_audit_recommendation_validation.gd",
      "arguments": [],
      "log": "logs/godot/pursue_goal/balance_depth_60/recommendation_contract_validation.log",
      "timeout_seconds": 300,
      "expected_token": "AI_AUDIT_RECOMMENDATION_VALIDATION_OK"
    },
    { "id": "protected_files_unchanged", "type": "protected_hashes" },
    { "id": "diff_check", "type": "git_diff_check" },
    { "id": "process_cleanup", "type": "process_clean" }
  ]
}
